# LLM Provider Keys
# The default model is gemini/gemini-2.0-flash (set in workspace/gateway.yaml).
GEMINI_API_KEY=your-gemini-api-key-here
WEATHER_API_KEY=your-open-weather-map-api-key

# Infrastructure (must match docker-compose.yml)
POSTGRES_URL=postgresql+asyncpg://agentgw:agentgw_dev@localhost:54320/agent_gateway
RABBITMQ_URL=amqp://agentgw:agentgw_dev@localhost:56720/

# Authentication
AGENT_GATEWAY_API_KEY=dev-api-key-change-me

# Notifications (optional — leave blank to disable)
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#agent-alerts
WEBHOOK_URL=
WEBHOOK_SECRET=
