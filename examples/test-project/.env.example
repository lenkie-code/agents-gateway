# LLM Provider Keys
# The default model is gemini/gemini-2.0-flash (set in workspace/gateway.yaml).
# Set your Gemini API key below:
GEMINI_API_KEY=your-gemini-api-key-here

# To use a different provider, update model.default in gateway.yaml and set the key:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
